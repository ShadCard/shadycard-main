# ============================================================================
# ShadyCard — API Server .env (Example)
# Copy to .env and fill in real values for your environment.
# ============================================================================

# ─── Database (MySQL 8.0+) ───────────────────────────────────────────────────
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE_NAME
# Examples:
#   Local:     mysql://root:password@localhost:3306/shadycard
#   PlanetScale: mysql://xxxxxxxx:yyyyyyyy@us-east.connect.psdb.cloud/shadycard?ssl={"rejectUnauthorized":true}
#   Railway:   mysql://root:password@containers-us-west-1.railway.app:6543/railway
DATABASE_URL=mysql://root:password@localhost:3306/shadycard

# Used by hasColumn() helper to query INFORMATION_SCHEMA
MYSQL_DATABASE=shadycard

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000
SESSION_SECRET=replace_with_a_strong_random_secret_at_least_32_chars

# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"

# ─── CORS (comma-separated list of allowed origins) ──────────────────────────
CLIENT_URL=http://localhost:5173,http://localhost:5174,https://your-store.vercel.app,https://your-admin.vercel.app

# ─── Telegram Bots ───────────────────────────────────────────────────────────
# Get tokens from @BotFather on Telegram
TELEGRAM_ADMIN_BOT_TOKEN=
TELEGRAM_STORE_BOT_TOKEN=

# Chat ID for admin notifications (group or channel). Get from @userinfobot
TELEGRAM_ADMIN_CHAT_ID=

# Random secret to protect admin webhook. Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TELEGRAM_ADMIN_WEBHOOK_SECRET=

# Public URL where the API is hosted (used to register Telegram webhooks)
PUBLIC_API_BASE_URL=https://your-api.onrender.com

# ─── SAM API (ShamCash automatic deposits) ───────────────────────────────────
# Get from SAM dashboard at https://sam-api.pro
SAM_API_KEY=
SAM_SHAMCASH_IDENTIFIER=
SAM_WEBHOOK_SECRET=
SAM_API_BASE_URL=https://sam-api.pro/api
SAM_PAY_BASE_URL=https://sam-api.pro

# ─── Optional Auth / Dev Settings ────────────────────────────────────────────
# Max age (in seconds) for Telegram init-data validation. Default: 24 hours
TELEGRAM_AUTH_MAX_AGE_SECONDS=86400

# Set to "true" only in development to allow unverified Telegram identity headers
ALLOW_UNVERIFIED_TELEGRAM_ID=false

# Set to "true" to allow a default Telegram ID fallback (dev only)
ALLOW_DEFAULT_TELEGRAM_ID=false
